// ========== UNION TYPES TESTS ==========

// --- Basic union ---
val name: string | null = null
val maybe: string | null = "hello"

// --- Multiple types union ---
val mixed: string | null | bool = true
val anyType: int | string | null = 42

// --- Union with array ---
val arr: int[] | string[] = [1, 2, 3]

// --- Union in function param ---
func test(a: string | null) {}
func multi(x: int | string | bool) {}

// --- Union return type ---
func get(): string | null { return null }

// --- Union with complex types ---
val complex: { name: string } | int[] | null = { name: "test" }

print("Union types tests passed!")