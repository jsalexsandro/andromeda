// ========== MORE KEY CASES ==========

// --- Keys com prefixos/sufixos ---
val prefixed = { _private: 1, $dollar: 2, __dunder: 3 }

// --- Keys very long ---
val long = { "thisIsAVeryLongKeyThatContainsManyCharacters": 1 }

// --- Keys com números no meio ---
val midNum = { key1: 1, key2: 2, key3: 3 }

// --- Multiple spreads ---
val s1 = { a: 1 }
val s2 = { b: 2 }
val combined = { ...s1, ...s2, "extra": 3 }

// --- Keys com ponto (não é propriedade válida, mas é key) ---
val withDot = { "a.b": 1, a: { b: 2 } }

// --- Keys dinâmicas via variáveis (não suportado - precisa de computed property) ---
// val dynKeys = ["k1", "k2"]
// val d1 = { [dynKeys[0]]: "v1", [dynKeys[1]]: "v2" }

// --- Keys aninhadas combinadas ---
val deepNested = { 
  "users": [
    { "id": 1, "name": "Alice" },
    { "id": 2, "name": "Bob" }
  ]
}
val getDeep = deepNested["users"][0]["name"]

print("More key cases passed!")