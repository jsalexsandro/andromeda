// ========== SPREAD/REST DEEP TESTS ==========

// --- Array Spread ---
val arr1 = [1, 2, 3]
val arr2 = [4, 5]
val merged = [...arr1, ...arr2]
val prepend = [...arr2, ...arr1]
val insert = [0, ...arr1, 99]
val nested = [...[...[...arr1]]]

// --- Object Spread ---
val obj1 = { a: 1, b: 2 }
val obj2 = { b: 3, c: 4 }
val objMerge = { ...obj1, ...obj2 }
val objOverride = { ...obj1, b: 999 }
val objNew = { ...obj1, d: 5 }

// --- Mixed Spread ---
val mixed = { ...obj1, arr: [...arr1] }

// --- Rest Parameters in Function ---
func fn1(...args) { }
func fn2(...args: int[]) { }
func fn3(a: int, ...rest: string[]) { }

// --- Spread with Ternary ---
val expr = [...(true ? arr1 : arr2)]
val cond = true
val dynamic = [...(cond ? arr1 : [])]

// --- Spread in Function Call ---
func sum(a: int, b: int, c: int): int { return a + b + c }
val result = sum(...arr1)

// --- Nested Objects with Spread ---
val deep = {
  level1: {
    level2: {
      ...obj1
    }
  }
}

// --- Array of Objects with Spread ---
val items = [{ id: 1 }, { id: 2 }]
val updated = [{ id: 0 }, ...items, { id: 3 }]

// --- Spread with Ternary ---
val ternary = [...(true ? [1, 2] : [3, 4])]
val doubleTernary = [...(cond ? (cond ? arr1 : arr2) : [])]

// --- Rest in Arrow Functions ---
val arrow1 = (...args) => args
val arrow2 = (...args: int[]) => args

// --- Multiple Spread ---
val multiSpread = [...arr1, ...arr2, ...[7, 8, 9]]

// --- Spread with Nullish ---
val nullableArr: int[] = null
val withNull = [...(nullableArr ?? [])]

// --- Deep Nested Spread ---
val deepNest = {
  data: [
    { ...obj1 },
    { ...obj2, extra: true }
  ]
}

// --- Spread with Function Types ---
val fns = [(x: int) => x * 2, (x: int) => x + 1]
val called = [...fns][0](5)

// --- Complex Case ---
val complex = {
  arr: [...arr1, ...(false ? [] : arr2)],
  nested: { ...{ a: [...arr1] } }
}

print("All spread/rest tests passed!")
