// ========================================
// Primitives & Undefined / Null Extended
// ========================================
val undef: undefined
val nul: null
val nothing: void
val anything: any
val unknownVal: unknown

// ========================================
// Literal Types Extended
// ========================================
val literalString: "ok" = "ok"
val literalFloat: 2.718 = 2.718
val literalFlag: false = false
val literalUnion: "a" | "b" = "a"
val literalNumberUnion: 1 | 2 | 3 = 2
val literalBoolUnion: true | false = false
val literalNull: null = null

// ========================================
// Tuple Types
// ========================================
val tup1: [string, int]
val tup2: [User, Product, bool]
val tup3: [Array<int>, Map<string, float>]
val tup4: [(int) => string, boolean]
val tup5: [[int, string], [bool, float]]
val tup6: [1, "hello", true]
val tup7: [string, int | null]
val tup8: [int]                              // single-element tuple
val tup9: []                                 // empty tuple

// ========================================
// Union Types Extended
// ========================================
val unionPrimitives: int | float | string | bool
val unionWithNull: User | Product | null
val unionLiterals: "red" | "green" | "blue"
val unionComplex: int | Array<int> | Map<string, User>
val unionFunction: (int) => string | (string) => int
val unionTuples: [int, string] | [string, int]
val unionMixed: int | "none" | null
val unionAny: any | null
val unionUnknown: unknown | string

// ========================================
// Function Types Extended
// ========================================
val funcReturnFunc: (int) => (string) => float
val funcTakeFunc: ((int) => string) => bool
val funcTakeTuple: ([int, string]) => boolean
val funcUnionParam: (int | string) => bool | null
val funcGenericParam: (Array<int>) => Map<string, bool>
val funcGenericReturn: (User) => Promise<Product>
val funcNestedGeneric: (Map<string, Array<int>>) => Set<bool>
val funcVoidParam: (void) => int
val funcUnknownParam: (unknown) => any
val funcAnyParam: (any) => void
val funcMultiArg: (int, string, bool) => User
val funcArrayReturn: (int) => string[]
val funcUnionArrReturn: (int) => (string | null)[]
val funcTupleReturn: (bool) => [int, string]
val funcNullableReturn: (bool) => [int, string] | null
val funcHigherOrder: (int) => ((int) => string)
val funcReturnFuncGrouped: (int) => ((string) => bool)
val funcComplex: (Map<string, Array<User>>) => Promise<(int) => boolean>

// ========================================
// Grouping Types Extended
// ========================================
val grpNested: ((int))
val grpUnionNested: ((int | string))
val grpFuncGroup: ((int) => string)
val grpArrFunc: ((int) => string)[]
val grpUnionArr: (int | string | null)[]
val grpTupleArr: ([int, string])[]
val grpLiteralArr: (1 | 2 | 3)[]
val grpLiteralStringArr: ("a" | "b")[]
val grpFuncReturnArr: (int) => (string)[]

// ========================================
// Deep Generics & Combinations
// ========================================
val deepGeneric1: Map<string, Map<int, Array<User>>>
val deepGeneric2: Promise<Array<Promise<User>>>
val genericUnion: Array<int | string>
val genericFunction: Map<string, (int) => boolean>
val genericTuple: Array<[string, int]>
val genericArrayFunc: Array<((int) => string)>
val genericMapFunc: Map<string, (User) => Product>
val genericPromiseVoid: Promise<void>
val genericPromiseUndef: Promise<undefined>
val genericPromiseNull: Promise<null>
val genericArrayAny: Array<any>
val genericMapUnknown: Map<unknown, any>
val genericArrayMap: Array<Map<string, (int) => void>>
val megacombo: Map<string, [int, (boolean) => string] | null>
val mega2: Array< (int | "default") => User[] >
val mega3: Map<string, ( (int) => string )[] >

// ========================================
// Nullable & Undefined variants
// ========================================
val nullableInt: int | null
val nullableString: string | undefined
val nullableUser: User | undefined
val nullOrUndef: null | undefined
val triple: int | null | undefined
val unionVoid: void | null