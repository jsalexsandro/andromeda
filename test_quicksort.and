func swap(arr: int[], i: int, j: int): void {
  val temp: int = arr[i]
  arr[i] = arr[j]
  arr[j] = temp
}

func partition(arr: int[], low: int, high: int): int {
  val pivot: int = arr[high]
  var i: int = low - 1
  var j: int = low
  while (j < high) {
    if (arr[j] <= pivot) {
      i += 1
      swap(arr, i, j)
    }
    j += 1
  }
  swap(arr, i + 1, high)
  return i + 1
}

func quicksort(arr: int[], low: int, high: int): void {
  if (low < high) {
    val pi: int = partition(arr, low, high)
    quicksort(arr, low, pi - 1)
    quicksort(arr, pi + 1, high)
  }
}

var arr: int[] = [64, 25, 12, 22, 11, 99, 3, 47, 58, 1]
quicksort(arr, 0, 9)
print(arr)
