// ========== INDEX ACCESS EDGE CASES ==========

// --- Index on null/undefined ---
val nullArr = null
// val nullAccess = nullArr[0]  // would error at runtime

// --- Index with nullish ---
val maybeNull: int[] = null
val safeAccess = (maybeNull ?? [0])[0]

// --- Index with boolean ---
val boolIdx = true
val arr2 = [false, true]

// --- Index with float (truncated) ---
val floatIdx = 1.9
val arr3 = [1, 2, 3]

// --- Zero index ---
val zero = arr[0]

// --- Last valid index ---
val lastValid = arr[arr.length - 1]

// --- Multiple index accesses in one expression ---
val multi = arr[0] + arr[1] + arr[2] + arr[3] + arr[4]

// --- Index in array spread ---
val idxSpread = [...arr, arr[0]]

// --- Index on nested member then index ---
val nestedObj = { data: { items: [1, 2, 3] } }
val nestedIdx = nestedObj.data.items[1]

// --- Index in function return ---
func nth(n: int, arr: int[]): int {
  return arr[n]
}
val fromNth = nth(2, arr)

// --- Index with function call as index ---
func getIdx(): int { return 1 }
val fromFnIdx = arr[getIdx()]

// --- Index in object property ---
val objIdx = { arr: [1, 2, 3], get: arr[0] }

// --- Index as array element ---
val arrayOfIndices = [arr[0], arr[1], arr[2]]

// --- Index in ternary chain ---
val chainTern = arr[0] > 0 ? arr[1] : (arr[2] > 0 ? arr[2] : arr[3])

// --- Index in logical expression ---
val chainLog = arr[0] && arr[1] || arr[2]

// --- Index in assignment target ---
var target = [0, 0, 0]
target[0] = arr[0]
target[1] = arr[1]

// --- Index post-increment/decrement ---
var postArr = [1, 2]
// postArr[0]++

// --- Index in object spread with index ---
val withIdx = { ...{ a: arr[0] }, b: arr[1] }

// --- Index comparison ---
val compare = arr[0] == arr[1]

// --- Index in method simulation ---
func map(arr: int[], fn): int[] {
  var result = []
  var i = 0
  while (i < arr.length) {
    result = [...result, fn(arr[i])]
    i = i + 1
  }
  return result
}

print("Index edge cases passed!")
