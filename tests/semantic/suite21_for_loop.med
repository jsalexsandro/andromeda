// ========================================
// TESTE: For Loop Statement
// ========================================

// 1. For básico com var
for (var i: int = 0; i < 5; i = i + 1) {
  val x: int = i
}

// 2. For com val (inicializador imutável)
for (val j: int = 0; j < 3; j = j + 1) {
  val y: int = j
}

// 3. For aninhado (teste de escopo)
for (var i: int = 0; i < 3; i = i + 1) {
  for (var k: int = 0; k < 3; k = k + 1) {
    val z: int = i + k
  }
}

// 4. For com break
for (var m: int = 0; m < 10; m = m + 1) {
  if (m == 5) break
  val w: int = m
}

// 5. For com continue
for (var n: int = 0; n < 5; n = n + 1) {
  if (n == 2) continue
  val v: int = n
}

// 6. For sem initializer (usa variável externa)
var idx: int = 0
for (; idx < 3; idx = idx + 1) {
  val t: int = idx
}

// 7. For sem condition (loop infinito com break)
for (var inf: int = 0;; inf = inf + 1) {
  if (inf > 5) break
}

// 8. For sem update (update dentro do body)
for (var p: int = 0; p < 3;) {
  val q: int = p
  p = p + 1
}
