// Teste Bug #1: Contexto propagado para arrow aninhada
val compose: ((int) => int, (int) => int) => (int) => int = 
  (f, g) => x => f(g(x))

// Teste Bug #2: Função nullable (sugestão de sintaxe)
val maybe_fn: ((int) => int) | null = null  // OK - sintaxe correta

