// ----------------------------------------
// Assignment básico
// ----------------------------------------
var x = 10
x = 20

// ----------------------------------------
// Compound assignment
// ----------------------------------------
var y = 5
y += 3
y -= 2
y *= 2
y /= 1
y %= 2

