// ========== OBJECT KEY ACCESS TESTS ==========

// --- Basic key access with string ---
val user = { name: "Alice", age: 30, city: "NYC" }
val name = user["name"]
val age = user["age"]
val city = user["city"]

// --- Key access with variable ---
val key = "name"
val byVar = user[key]

// --- Key access with expression ---
val byExpr = user["na" + "me"]

// --- Key not found ---
val missing = user["nonexistent"]

// --- Nested key access ---
val deep = { a: { b: { c: 42 } } }
val deepKey = deep["a"]["b"]["c"]

// --- Mixed dot and bracket ---
val mixed = { outer: { inner: 1 } }
val mixedKey = mixed["outer"].inner

// --- Key with number (not supported in object literal) ---
// val numObj = { 0: "zero", 1: "one" }
// val numKey = numObj[0]

print("Object key access tests passed!")
