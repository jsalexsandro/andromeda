// ========== UNION TYPES - COMPLEX CASES ==========

// --- UNION WITH IDENTIFIER TYPES ---
val customUnion: Identifier | string | null = "hello"

// --- UNION IN OBJECT (simple values) ---
val container = {
  value: "hello",
  name: "Alice"
}

// --- UNION + TERNARY ---
val tern = true ? "yes" : null

// --- UNION + NULLISH ---
val nullish = value ?? null

// --- UNION IN LOOP ---
var loopCounter = 0
while (loopCounter < 5) {
  loopCounter = loopCounter + 1
}

// --- FUNCTION UNION PARAM ---
func process(a: string | null, b: int | string | null) {}

// --- ARROW WITH UNION ---
val arrow1 = (x: string | null): string | null => x
val arrow2 = (a: int | string, b: bool | null): int | null => a

// --- UNION TYPE VARIABLE ---
val unionValue: string | int | bool | null = "test"

print("Complex union tests done!")