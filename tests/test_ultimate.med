// Uma função que recebe uma função, que retorna uma função, 
// que retorna um objeto com uma função, que retorna um array de funções.
val ultimate: ((int) => (string) => { exec: () => ((bool) => void)[] }) => void = 
    (f) => f(1)("teste").exec()[0](true)

// Tipagem de callback que retorna uma promessa fake (objeto) com função
val handler: { 
    onSuccess: ( {data: string, code: int} ) => (bool) => { status: string } 
} = {
    onSuccess: (obj) => (b) => ({ status: "ok" })
} 
