// ========== SPREAD/REST EDGE CASES ==========

// --- Spread em contextos incomuns ---

// Spread como primeiro argumento
val start = [...[1, 2], 3]

// Spread no meio
val middle = [1, ...[2, 3], 4]

// Spread após outros elementos
val after = [1, 2, ...[3, 4]]

// Spread apenas
val only = [...[1, 2, 3]]

// Spread vazio
val empty = [...[]]

// Spread com expressões complejas
val complex = [...(a ?? []), ...(b ? c : d)]

// --- Rest em contexts incomuns ---

// Rest único
func rest1(...items) { }

// Rest com outros params
func rest2(a, ...rest) { }

// Rest com tipo
func rest3(...items: int[]) { }

// Rest em arrow
val arrowRest = (...x) => x
val arrowRestTyped = (...x: string[]) => x

// --- Spread em chamada de função com múltiplos argumentos ---
func multiArgs(a, b, c, d) { }
val arr4 = [1, 2, 3, 4]
multiArgs(...[1, 2], ...[3, 4])

// --- Spread com object expression ---
val objA = { ...{ a: 1 }, ...{ b: 2 } }

// --- Spread dentro de ternário complexo ---
val t1 = true
val t2 = false
val ternSpread = [...(t1 ? [1] : []), ...(t2 ? [2] : [3])]

// --- Spread com operadores unários ---
val unary = [1, ...[-(2)], ...[+3]]

// --- Rest em funções variádicas ---
func sumAll(...nums: int[]): int { 
  var total = 0
  var i = 0
  while (i < nums.length) {
    total = total + nums[i]
    i = i + 1
  }
  return total
}
val sumResult = sumAll(1, 2, 3, 4, 5)

// --- Spread de resultado de função ---
func getArray(): int[] { return [1, 2, 3] }
val fromFn = [...getArray()]

// --- Múltiplos spreads aninhados profundo ---
val deep = [...[...[...[1, 2, 3]]]] 

// --- Spread em object spread aninhado ---
val nestedObj = { a: { ...{ b: 1 } } }

// --- Spread com index access ---
val arrIdx = [1, 2, 3]
val idx = 0
val fromIdx = [...arrIdx, arrIdx[idx]]

// --- Spread com member access ---
val objMember = { arr: [1, 2, 3] }
val fromMember = [...objMember.arr]

print("Edge cases passed!")
