// ========== OBJECT KEY EDGE CASES ==========

// --- Keys com caracteres especiais ---
val special = { 
  "kebab-case": 1,
  "snake_case": 2,
  "camelCase": 3,
  "PascalCase": 4,
  "with spaces": 5,
  "with.dots": 6,
  "with:colons": 7,
  "@symbol": 8,
  "#hash": 9,
  "/path/like": 10
}

// --- Keys com números (positivos apenas) ---
val nums = { 0: "a", 1: "b", 2: "c", 100: "d" }

// Keys com expressões entre aspas (não suportado)
// val withExpr = { "a" + "b": "ab" }

// --- Keys que são Keywords ---
val keywords = { if: 1, else: 2, while: 3 }

// --- Keys que são Types ---
val types = { int: 1, string: 2, bool: 3 }

// --- Access patterns ---
val getSpecial = special["kebab-case"]
val getNeg = negNum[-1]  // Should work
val getUnicode = unicode["日本語"]

// --- Bracket access with variables ---
val key = "camelCase"
val getByVar = special[key]

// --- Nested object with special keys ---
val nested = { 
  "level1": { 
    "level-2": { 
      "deep-key": 42 
    } 
  } 
}

// --- Array of objects ---
val arrObj = [
  { "0": "a", "1": "b" },
  { "name": "test" }
]

// --- Spread with special keys ---
val base = { a: 1 }
val extended = { ...base, "special-key": 42 }

// --- Computed-style keys (simulated via variable) ---
val computedKey = "computed"
val compute = { "computed": 123 }

// --- Keys in function ---
func getKey(obj, key) {
  return obj[key]
}
val fromFn = getKey(special, "snake_case")

print("Object key edge cases passed!")