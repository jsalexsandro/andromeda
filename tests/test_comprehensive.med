func compose(f: (int) => int, g: (int) => int): (int) => int {
  return (x) => f(g(x))
}

// OK - array de arrows curried
val curried_ops: ((int) => (int) => int)[] = [
  (a) => (b) => a + b,
  (a) => (b) => a * b,
  (a) => (b) => a - b,
]

// OK - HOF que retorna arrow
func make_adder(n: int): (int) => int {
  return (x) => x + n
}
val add5 = make_adder(5)
val add5_result = add5(10)

// OK - array de HOFs que retornam arrows
val makers: ((int) => (int) => int)[] = [
  (n) => (x) => x + n,
  (n) => (x) => x * n,
]

// ERRO - HOF que retorna arrow com tipo errado no body interno
func bad_maker(n: int): (int) => int {
  return (x) => "nao int"
}

// OK - compose sobre elemento de array de arrows
val fns: ((int) => int)[] = [
  (x) => x + 1,
  (x) => x * 2,
  (x) => x - 3,
]
val chained = compose(fns[0], fns[1])

// ERRO - curry de 4 níveis com tipo errado no nível mais fundo
val deep_bad: (int) => (int) => (int) => (int) => int =
  (a) => (b) => (c) => (d) => "quatro niveis e errado"

// OK - curry de 4 níveis correto
val deep_ok: (int) => (int) => (int) => (int) => int =
  (a) => (b) => (c) => (d) => a + b + c + d

// ERRO - arrow recebe arrow como param e chama com tipo errado
func apply_fn(f: (int) => int, x: int): int {
  return f(x)
}
val inner: (string) => string = (s) => s + "!"
val bad_apply = apply_fn(inner, 10)

// OK - arrow de ordem superior: recebe arrow, retorna arrow
func transform(f: (int) => int): (int) => int {
  return (x) => f(x) + 1
}
val shifted = transform((x) => x * 2)
val shifted_result = shifted(5)

// ERRO - transform com arrow de tipo errado
val bad_shifted = transform((x) => "string")