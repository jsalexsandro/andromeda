// ========== COMPREHENSIVE SPREAD TESTS ==========

// --- BASIC SPREAD ---
val basic1 = [1, 2, 3]
val basic2 = [...basic1]
val basic3 = [...basic1, ...basic1]
val basic4 = [0, ...basic1, 99]

// --- OBJECT SPREAD ---
val obj1 = { a: 1, b: 2 }
val obj2 = { c: 3 }
val objSpread = { ...obj1, ...obj2 }
val objSpreadOverride = { ...obj1, b: 999 }

// --- REST PARAMETERS ---
func rest1(...args) { }
func rest2(a, ...rest) { }
func rest3(...nums: int[]) { }

// --- ARROW WITH REST ---
val arrowRest1 = (...args) => args
val arrowRest2 = (...nums: int[]) => nums

// --- SPREAD IN FUNCTION CALL ---
func fn3Args(a, b, c) { }
fn3Args(...basic1)
fn3Args(...[1, 2], 3)
fn3Args(1, ...[2, 3])

// --- SPREAD WITH TERNARY ---
val tern = true
val ternSpread = [...(tern ? [1, 2] : [3])]
val doubleTern = [...(tern ? (tern ? [1] : [2]) : [3])]

// --- SPREAD WITH NULLISH ---
val maybenull = null
val nullishSpread = [...(maybenull ?? [1, 2])]

// --- SPREAD IN ARRAY LITERAL ---
val nested = [...[...[...[1, 2, 3]]]]
val multi = [...[1], ...[2], ...[3]]

// --- SPREAD IN OBJECT LITERAL ---
val objNested = { a: { b: { c: [1, 2] } } }
val fromNested = [...objNested.a.b.c]

// --- SPREAD EXPRESSION ---
val x = 1
val y = 2
val expr = [...[x + y, x - y, x * y]]

// --- SPREAD WITH UNARY ---
val unary = [...[-1, -2, -3]]
val notSpread = [true, ...[!false]]

// --- SPREAD DEEP NESTED ---
val d1 = [1]
val d2 = [...d1]
val d3 = [...d2]
val d4 = [...d3]
val d5 = [...d4]

// --- SPREAD CHAINED ---
func getArr(): int[] { return [1, 2, 3] }
val fromFn = [...getArr()]

// --- SPREAD IN ASSIGNMENT ---
var mutable = [1, 2]
mutable = [...mutable, 3]

// --- SPREAD COMPARISON ---
val cmp = [
  1 == 1,
  2 != 3,
  3 < 4,
  5 > 4
]

// --- SPREAD LOGICAL ---
val logical = [
  true && false,
  true || false,
  !!!false,
  (1 > 0) && (2 < 3)
]

// --- SPREAD TYPEOF ---
val t = typeof([1, 2, 3])

// --- SPREAD WITH MEMBER ACCESS ---
val memberObj = { arr: [1, 2, 3] }
val fromMember = [...memberObj.arr]

// --- SPREAD WITH INDEX ---
val idx = 0
val indexed = [...basic1, basic1[idx]]

// --- SPREAD IN OBJECT SPREAD ---
val os1 = { a: 1 }
val os2 = { b: [1, 2] }
val os3 = { ...os1, arr: [...os2.b] }

print("All comprehensive spread tests passed!")
