// ========== ADVANCED SPREAD/REST TESTS ==========

// --- Arrays básicos ---
val arrInt = [1, 2, 3]
val arrStr = ["a", "b"]
val arrNested = [[1, 2], [3, 4]]

// --- Spread em chamada de função ---
func concatString(...parts: string[]): string {
  var result = ""
  var i = 0
  while (i < parts.length) {
    result = result + parts[i]
    i = i + 1
  }
  return result
}
val joined = concatString(...["Hello", " ", "World"])

// --- Spread com index access ---
val numbers = [10, 20, 30, 40, 50]
val firstItem = numbers[0]
val lastItem = numbers[numbers.length - 1]

// --- Spread em array de objetos ---
val items = [{ id: 1 }, { id: 2 }, { id: 3 }]
val first = items[0]
val last = items[items.length - 1]

// --- Spread com expressões complexas no valor ---
val x = 1
val y = 2
val exprSpread = [...[x + y, x * y, x - y]]

// --- Spread em chamada com múltiplos argumentos ---
func variadic(a: int, b: int, ...rest: int[]): int[] {
  return [...rest, a, b]
}
val variadicResult = variadic(1, 2, ...[3, 4, 5])

// --- Spread encadeado ---
val original = [1, 2, 3]
val combined = [...original, ...original, ...[4, 5]]

// --- Spread com ternary ---
val condA = true
val condB = false
val deepTernary = [
  ...(condA ? [1, 2] : [3]),
  ...(condB ? [4] : [5, 6])
]

// --- Spread em arrow function ---
val createArray = (...items) => [...items]
val created = createArray(1, 2, 3)

// --- Spread com rest em arrow ---
val useRest = (first, ...rest) => rest
val restResult = useRest(1, 2, 3, 4)

// --- Spread com nullish coalescing ---
val maybeNull = null
val withNull = [...(maybeNull ?? [99, 100])]

// --- Spread em objeto aninhado ---
val deep = {
  level1: {
    data: [1, 2, 3]
  }
}
val extracted = [...deep.level1.data]

// --- Múltiplos spreads ---
val a = [1]
val b = [2]
val c = [3]
val combined2 = [...a, ...b, ...c, ...[4], ...(condA ? a : [])]

// --- Spread em funções aninhadas ---
func outer(): int[] {
  func inner(...args: int[]): int[] {
    return args
  }
  return inner(...[1, 2, 3])
}
val nestedResult = outer()

// --- Spread com ternary longo ---
val longCond = true
val result = [
  ...(longCond ? (true ? [1, 2] : [3]) : [4]),
  5
]

// --- Spread com filter/map simulados ---
val range = [0, 1, 2, 3, 4]
// Simulação sem métodos nativos

// --- Spread em objeto com arrays ---
val config = {
  defaults: [1, 2, 3]
}
val final = [...config.defaults]

// --- Spread com typeof ---
val typeCheck = typeof([...arrInt])

// --- Spread profundo aninhado ---
val deepNest = [...[...[...[1, 2, 3]]]]

// --- Spread com operadores binários ---
val binOps = [
  1 + 2,
  3 - 1,
  2 * 4,
  10 / 2,
  5 % 3
]

// --- Spread em condição ---
val condition = true
val conditionalSpread = condition ? [...[1, 2]] : [...[3, 4]]

// --- Spread com negate unário ---
val negSpread = [...[-1, -2, -3]]

// --- Spread em assignment target ---
var target = [1, 2, 3]
target = [...target, 4]

// --- Spread misto array + objeto ---
val mixed = [...[1, 2, 3], { a: 1 }]

// --- Spread e operador spread no mesmo contexto ---
val both = [...[1, 2], ...[3, 4], ...[5, 6]]

// --- Spread com comparison operators ---
val cmp = [
  1 == 1,
  2 != 3,
  3 < 4,
  5 > 4,
  5 <= 5,
  6 >= 6
]

// --- Spread com logical operators ---
val logical = [
  true && false,
  true || false,
  !!!true,
  1 > 0 && 2 < 3
]

// --- Spread com nullish coalescing ---
val nullish = [
  null ?? 1,
  undefined ?? [1, 2],
  ...(null ?? [3, 4])
]

// --- Spread em função que retorna array ---
func getArray(): int[] { return [1, 2, 3] }
val fromFn = [...getArray()]

// --- Spread com augmented assignment ---
var count = 0
count += 1

print("Advanced spread tests completed!")
