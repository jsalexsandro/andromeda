// Unários repetidos e nullish
val logic = !!!(true ?? false)

// Função que aceita qualquer coisa e não retorna nada
func logger(...payload: any[]): void {
    print(...payload)
}

// Tipo de objeto com campos que são tuplas de funções
var registry: {
    hooks: [(int) => void, (string) => bool],
    active: bool
} = {
    hooks: [(n: int) => {}, (s: string) => true],
    active: !!!false
}
