// ========== INDEX ACCESS TESTS ==========

// --- Basic index access ---
val arr = [10, 20, 30, 40, 50]
val first = arr[0]
val second = arr[1]
val last = arr[4]
val outOfBounds = arr[100]

// --- Index with variable ---
val idx = 2
val atIdx = arr[idx]

// --- Index with expression ---
val expr = arr[1 + 1]
val expr2 = arr[idx + 1]

// --- Nested index ---
val nested = [[1, 2], [3, 4], [5, 6]]
val nestedFirst = nested[0]
val nestedDeep = nested[0][0]

// --- Index on object (computed) ---
val obj = { a: 1, b: 2 }
val viaIndex = obj["a"]
val viaIndexVar = obj["b"]

// --- Index on member access ---
val container = { items: [1, 2, 3] }
val fromMember = container.items[0]

// --- Chained index access ---
val matrix = [[1, 2], [3, 4]]
val cell = matrix[1][0]

// --- Index with negative (if supported) ---
// val neg = arr[-1]

// --- Index assignment ---
var mutable = [1, 2, 3]
mutable[0] = 99

// --- Index in expression ---
val computed = arr[0] + arr[1] * arr[2]

// --- Index in condition ---
if (arr[0] > 0) {
  val x = 1
}

// --- Index in function call ---
func getFirst(arr: int[]): int {
  return arr[0]
}
val result = getFirst(arr)

// --- Index in array literal ---
val newArr = [arr[0], arr[1], arr[2]]

// --- Index in spread ---
val spreadFromIndex = [...arr, arr[0]]

// --- Index in object literal ---
val withIndex = { first: arr[0], second: arr[1] }

// --- Index in ternary ---
val tern = arr[0] > 10 ? arr[0] : arr[1]

// --- Index in while ---
var i = 0
var sum = 0
while (i < arr.length) {
  sum = sum + arr[i]
  i = i + 1
}

// --- Index on string ---
val str = "hello"
val char0 = str[0]
val charLast = str[str.length - 1]

// --- Index on function result ---
func getArray(): int[] { return [1, 2, 3] }
val fromFn = getArray()[0]

// --- Deep index chain ---
val deep = { a: { b: { c: [1, 2, 3] } } }
val deepIdx = deep.a.b.c[0]

// --- Index as key in object ---
// Computed property names not yet supported
// val key = "dynamic"
val dynamicObj = { dynamic: 42 }

print("Index access tests passed!")
