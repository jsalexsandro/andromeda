// 1. Definição de um tipo que é um array de tuplas de funções 
// que retornam objetos com métodos que retornam tipos any
val godMode: [ ((int, string) => { run: () => any })[] ][] = []

// 3. O "Inception" de Arrow Functions
val brainMelter = [
    { deep: (x: int) => (y: int) => (z: int): int => x + y + z }
]

// 4. Acesso e Execução
val finalValue = brainMelter[0].deep(1)(2)(3) == 6 ? "Perfeito" : "Erro" 
