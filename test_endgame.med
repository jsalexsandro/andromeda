// 3. O "Inception" de Arrow Functions
// Uma arrow function que retorna outra, que retorna outra, 
// usada como valor em um objeto, dentro de um array.
val brainMelter = [
    { 
        deep: (x: int) => (y: int) => (z: int): int => x + y + z 
    }
]

// 4. Acesso e Execução
val finalValue = brainMelter[0].deep(1)(2)(3) == 6 ? "Perfeito" : "Erro" 
