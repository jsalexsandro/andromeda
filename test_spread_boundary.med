// ========== SPREAD EDGE CASES - BOUNDARY TESTS ==========

// --- SPREAD AS ONLY ELEMENT ---
val only = [...[1]]
val onlyEmpty = [...[]]

// --- SPREAD MULTIPLE TIMES SAME ARRAY ---
val same = [1, 2]
val multiSame = [...same, ...same, ...same]

// --- SPREAD IN MIDDLE OF EXPRESSION ---
val mid = [...[1], 2, ...[3], 4, ...[5]]

// --- SPREAD WITH OBJECT ---
val objA = { a: 1 }
val spreadObj = { ...objA }

// --- SPREAD IN NESTED OBJECT ---
val nest = { outer: { inner: [...[1, 2]] } }

// --- SPREAD WITH ARROW FUNCTION ARG ---
val arrowArg = [...[(x) => x * 2]]
val arrowCall = arrowArg[0](5)

// --- SPREAD WITH TERNARY NESTED 3 LEVELS ---
val lvl1 = true
val lvl2 = false
val lvl3 = true
val deepTern = [
  ...(lvl1 ? (lvl2 ? (lvl3 ? [1] : [2]) : [3]) : [4])
]

// --- SPREAD WITH NULLISH CHAIN ---
val nullable = null
val chain = [...(nullable ?? (null ?? [1]))]

// --- SPREAD IN WHILE LOOP ---
val arr = [1, 2, 3]
var idx = 0
var sum = 0
while (idx < arr.length) {
  sum = sum + arr[idx]
  idx = idx + 1
}

// --- SPREAD RECURSIVE ---
func recurse(n: int): int[] {
  if (n == 0) {
    return []
  }
  return [...recurse(n - 1), n]
}
val recursed = recurse(5)

// --- SPREAD HIGHER ORDER ---
val hof = (arr: int[]): int[] => [...arr, 99]
val applied = hof([1, 2, 3])

// --- SPREAD COMPOUND ASSIGNMENT ---
var compound = [1]
compound = [...compound, 2]

// --- SPREAD IN FUNCTION CHAIN ---
func add10(x: int): int { return x + 10 }
func multiply2(x: int): int { return x * 2 }
val chained = add10(multiply2(5))

// --- SPREAD LITERAL WITH ALL TYPES ---
val allTypes = [
  1,
  1.5,
  true,
  "string",
  null,
  [1, 2],
  { a: 1 }
]

// --- SPREAD IN RETURN ---
func returnSpread(): int[] {
  return [...[1, 2, 3]]
}

// --- SPREAD SWAP ---
val swap1 = [1, 2, 3]
val swap2 = [4, 5, 6]
val swapped = [...swap2, ...swap1]

// --- SPREAD EMPTY MERGE ---
val empty1 = []
val empty2 = []
val emptyMerge = [...empty1, ...empty2]

// --- SPREAD SINGLETON ---
val single = [42]
val asSingleton = [...single, ...single]

// --- SPREAD WITH NEGATIVE NUMBERS ---
val negatives = [-1, -2, -3]
val negSpread = [...negatives, 0, ...[-4, -5]]

// --- SPREAD INCREMENT/DECREMENT ---
var inc = [1, 2]
val lastIdx = inc.length - 1

// --- SPREAD WITH BREAK ---
var breakTest = 0
var i = 0
while (i < 10) {
  i = i + 1
  if (i == 5) {
    break
  }
  breakTest = breakTest + i
}

// --- SPREAD WITH CONTINUE ---
var continueTest = 0
var j = 0
while (j < 5) {
  j = j + 1
  if (j == 2) {
    continue
  }
  continueTest = continueTest + j
}

// --- SPREAD DEEP RECURSION ---
func deep(n: int): int[] {
  if (n <= 0) {
    return []
  }
  return [n, ...deep(n - 1)]
}
val deepRec = deep(3)

print("Edge cases boundary tests passed!")
