// ========== EXTREME SPREAD/REST EDGE CASES ==========

// --- Spread em contextos inesperados ---

// Spread após descanso (impossível, mas documenta)
val simple = [1, 2, 3]

// Spread com pipe-like patterns
val pipe = [...[1, 2, 3].filter(x => x > 1)]

// Spread em template string
val tmpl = `Array: ${[...simple]}`

// Spread em type annotation position
val typed: int[] = [1, 2, 3]

// Spread como default de param
func withDefault(arr = [...[1, 2, 3]]) { }
withDefault()

// --- Spread com expressões cada vez mais complexas ---

// Expressão matemática no spread
val mathInSpread = [...[1 + 1, 2 * 2, 3 ** 2]]

// Expressão com parênteses
val parenExpr = [...[(1 + 2) * 3]]

// Operador condicional no spread
val condInSpread = [...[true ? 1 : 0, false ? 2 : 3]]

// Múltiplos nullish no spread
val multiNullish = [...[null ?? 1, undefined ?? 2, null ?? [3, 4]]]

// --- Spread em contextos de função ---

// Spread como default
func defaults(a = [...[1]], b = 2) { }
defaults()
defaults(...[10], 20)

// Spread em rest position
func restOnly(...everything) { }
restOnly(1, 2, 3)
restOnly(...[1, 2, 3])

// Spread mixed com args normais
func mixedArgs(a, ...rest, b) { }  // b após rest seria erro em JS, mas testa

// --- Spread em estruturas complexas ---

// Objeto com método que retorna array
val objWithMethod = {
  getItems: (): int[] => [1, 2, 3]
}
val fromMethod = [...objWithMethod.getItems()]

// Array de objetos com spread
val objArr = [{ a: 1 }, { b: 2 }]
val spreadObjArr = [...objArr, { c: 3 }]

// Spread em array de functions
val fns = [(x) => x + 1, (x) => x * 2]
val fnSpread = [...fns]

// --- Edge cases de precedência ---

// Spread vs multiplicação
val precedence1 = [...[1, 2]] * 2

// Spread vs member access
val precedence2 = [...[1, 2, 3]].length

// Spread vs call
val precedence3 = [...[1, 2, 3]].toString()

// Spread vs index
val precedence4 = [...[1, 2, 3]][0]

// --- Spread em contextos de controle ---

// Spread no while condition (sem sentido mas testa)
var loopArr = [1, 2, 3]
while (...loopArr) { }  //Isso seria erro

// Spread no for init
// for (...[1, 2, 3]) { }  // erro

// Spread como condition
val spreadAsCond = [...[true]] && "yes"

// --- Spread com Symbol/unique ---
// Symbol não suportado ainda

// --- Spread aninhado profundo ---
val deep1 = [1]
val deep2 = [...deep1]
val deep3 = [...deep2]
val deep4 = [...deep3]
val deep5 = [...deep4]
val deep6 = [...deep5]

// --- Spread com comments ---
val withComments = [
  ...[/* comment */1, 2],
  .../* inline */ [3, 4]
]

// --- Spread em type positions ---
val type1: int[] = [...[1]]
val type2: int[][] = [...[[1, 2]]]

// --- Spread em import/export simulation ---
// val exported = [...[1, 2]]
// export { exported }

// --- Spread comtry/catch/finally ---
try {
  val inTry = [...[1, 2]]
} catch (e) {
  val inCatch = [...[3, 4]]
} finally {
  val inFinally = [...[5, 6]]
}

// --- Spread em classes (se suportado) ---
class Container {
  items: int[]
  
  constructor(...items: int[]) {
    this.items = items
  }
  
  getItems(): int[] {
    return [...this.items]
  }
}

val container = Container(1, 2, 3)
val fromContainer = [...container.getItems()]

// --- Spread em object fields ---
val field = {
  list: [1, 2, 3],
  getList: (): int[] => [...this.list]
}

print("Extreme spread tests completed!")
